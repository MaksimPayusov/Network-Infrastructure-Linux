$ORIGIN .
$TTL 604800	; 1 week
lab.local		IN SOA	lab.local. admin.lab.local. (
				2026042113 ; serial
				604800     ; refresh (1 week)
				86400      ; retry (1 day)
				2419200    ; expire (4 weeks)
				604800     ; minimum (1 week)
				)
			NS	ns.lab.local.
			A	10.0.0.2
$ORIGIN lab.local.
gw			A	10.0.0.1
ns			A	10.0.0.2
services		A	10.0.0.2
