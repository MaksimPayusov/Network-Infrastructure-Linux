$ORIGIN .
$TTL 604800	; 1 week
0.0.10.in-addr.arpa	IN SOA	lab.local. admin.lab.local. (
				2026042106 ; serial
				604800     ; refresh (1 week)
				86400      ; retry (1 day)
				2419200    ; expire (4 weeks)
				604800     ; minimum (1 week)
				)
			NS	ns.lab.local.
$ORIGIN 0.0.10.in-addr.arpa.
1			PTR	gw.lab.local.
2			PTR	services.lab.local.
